<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
    <id>com.transkit.transkit</id>
    <name>TransKit</name>
    <summary>A text translation, OCR and realtime monitor app</summary>
    <developer id="com.transkit">
        <name>transkit-app</name>
    </developer>
    <url type="homepage">https://transkit.app/</url>
    <url type="bugtracker">https://github.com/transkit-app/transkit-desktop/issues</url>
    <metadata_license>CC0-1.0</metadata_license>
    <project_license>GPL-3.0-only</project_license>
    <description>
        <p>TransKit is a cross-platform desktop app for translation, OCR, realtime speech monitoring, and TTS workflows.</p>
        <p>Key features:</p>
        <ul>
            <li>Realtime speech transcription and translation monitor</li>
            <li>Sub Mode for subtitle-style overlay</li>
            <li>AI suggestion and context generation</li>
            <li>Bookmark timeline and transcript auto-save</li>
            <li>Multi-provider translation and OCR</li>
            <li>TTS with BYO API model (free + premium providers)</li>
        </ul>
    </description>
    <launchable type="desktop-id">com.transkit.transkit.desktop</launchable>
    <screenshots>
        <screenshot type="default">
