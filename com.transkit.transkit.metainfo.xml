    <releases>
        <release version="3.1.0" date="2026-03-19">
            <url type="details">https://github.com/transkit-app/transkit-desktop/releases/tag/3.1.0</url>
            <description>
                <p>First independent TransKit release line.</p>
                <ul>
                    <li>Enhanced realtime monitor workflow</li>
                    <li>Added sub mode, AI suggestions, bookmarks and transcript auto-save</li>
                    <li>Expanded TTS providers with BYO API model</li>
                    <li>Updated project documentation and release process</li>
                </ul>
            </description>
        </release>
    </releases>
