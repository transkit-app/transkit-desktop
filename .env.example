# Transkit Cloud (Supabase)
# Copy this file to .env and fill in values to enable cloud features.
# Leave empty to build in local-only mode (no auth, no Soniox trial).
# Official releases inject these via CI secrets — end users never need a .env.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Uncomment to force local-only mode even when credentials are present:
# VITE_DISABLE_CLOUD=true
